	WhetstoneExtractor: {
		DisplayName: 砥石提取器
		Tooltip:
			'''
			允许你从武器中提取对应暴击条件的砥石
			使用方法：光标持有你想要提取的武器对着 [i:CritRework/WhetstoneExtractor]砥石提取器 右键点击
			同时会移除武器的暴击条件和前缀，并附加“碎裂”前缀
			'''
	}

	DivineShard: {
		DisplayName: 神化锭
		Tooltip:
			'''	
			可被用于给武器附魔 [icon] [c/fffaac:暴击重锻] [icon]
			暴击重锻根据武器暴击条件而改变，且每个都是唯一的
			使用方法：光标持有你想要附魔的武器对着 [i:CritRework/DivineShard]神化锭 右键点击
			“某位神祗所持砥石的一块碎片”
			'''
	}

