			武器每安装一个强化部件增加8%暴击率
			'''
	}

	Ambrosia: {
		CanBeApplied: ""
		DisplayName: 神肴
		Tooltip:
			'''
			当被安装在武器上时，会禁用普通暴击
			相反，暴击会减少所有减益的时间，包括耐药性
			减少的时间与暴击伤害倍率和效力有关
			'''
