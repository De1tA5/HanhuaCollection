	BouncyBall: {
		CanBeApplied: ""
		DisplayName: 弹力球
		Tooltip:
			'''
			当被安装在武器上时，会禁用普通暴击
			相反，暴击会增加攻击造成的击退力
			击退大小与暴击伤害倍率和效力有关
			'''
	}

	FatedFlame: {
		DisplayName: 命定之焰
		Tooltip:
			'''
			当你生命值至少低于50%时，增加30%暴击效力
			“火焰从两端燃烧”
			'''
	}

	LastStraw: {
		DisplayName: 最后的稻草
		Tooltip:
			'''
			当你生命值至少低于50%时，增加30%暴击效力
			敌怪的生命值越低，提升的暴击伤害越高，最高25%
			“增加对骆驼造成的伤害”
			'''
	}

	CrownShard: {
		DisplayName: 王冠碎片
		Tooltip: 具有暴击重锻的武器增加20%暴击率
	}

	ReuinitedCoronet: {
		DisplayName: 重锻之冠
		Tooltip:
