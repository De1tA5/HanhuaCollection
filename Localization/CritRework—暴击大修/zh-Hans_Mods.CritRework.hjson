Configs: {
	ClientConfig: {
		DisplayName: 客户端设置
		Headers.AestheticHeader: 美术相关

		overrideCritColor: {
			Label: 覆盖原版暴击颜色
			Tooltip: 启用后，能改变暴击文本的颜色（见下）
		}

		critColor: {
			Label: 暴击颜色
			Tooltip: 如果上述设置启用，则更改暴击文本的颜色
		}

		critSoundEffect: {
			Label: 暴击音效
			Tooltip: 启用/禁用击中敌怪时的暴击音效
		}

		showActiveCrits: {
			Label: 物品栏显示激活暴击物品
			Tooltip: 启用后，物品栏中满足暴击条件的物品将高亮显示
		}

		hideGloveDescription: {
			Label: 隐藏手套教程
			Tooltip: 启用后，手套的教程说明将从其工具提示中移除以减少冗杂信息
		}

		abbreviateWhetstoneTooltip: {
			Label: 简化砥石文本
			Tooltip: 启用后，砥石的教程说明将从其工具提示中移除以减少冗杂信息
		}

		abbreviateAugmentationTooltip: {
			Label: 简化强化部件文本
			Tooltip: 启用后，强化部件的教程说明将从其工具提示中移除以减少冗杂信息
		}
	}

	ServerConfig: {
		DisplayName: 服务器设置

		Headers: {
			BalanceHeader: 平衡
			ContentHeader: 内容
		}

		critPower: {
			Label: 暴击强度
			Tooltip:
				'''
				允许你调整暴击伤害强度
				设置为 0 ，则所有暴击伤害和普通伤害相同
				设置为 2 ，则所有暴击伤害翻倍
				'''
		}

		pirateHijack: {
			Label: 海盗劫持
			Tooltip:
				'''
				启用后，海盗有新特性
				允许你在不重铸的情况下改变武器的暴击条件
				'''
		}

		randomHijackChance: {
			Label: 重铸劫持概率
			Tooltip: 在哥布林工匠重铸时武器有概率被“劫持”，将会改变武器暴击条件
		}

		randomHijackSound: {
			Label: 重铸劫持音效
			Tooltip: 启用后，在武器被劫持时发生特殊音效（见上）
		}

		pirateArmorRework: {
			Label: "[i:876]海盗套装重做"
			Tooltip: 启用后，由海盗出售的[i:876]海盗时装 具有实际盔甲效果
		}

		gloveDamageType: {
			Label: 手套/标枪职业伤害
			Tooltip:
				'''
				该伤害类型将应用于手套/标枪武器
				如果未启用《灾厄》模组，且设置为盗贼，则默认为远程伤害
				请在Steam创意工坊上评论任何你认为应该添加的伤害类型
				'''
		}

		critScaling: {
			Label: 暴击倍率计算方式
			Tooltip:
				'''
				根据暴击伤害倍率/暴击率加成，决定暴击伤害的计算方式
				最推荐“平衡”模式，但“简单”模式通常更强且易于理解，你可能更喜欢
				平衡 - （（武器伤害倍率-1）*（（100+武器暴击率）/99）/2+1）+1)*(1+(（100+武器暴击率）/99)/2)
				简单 - 武器伤害倍率 * （1+武器暴击率）
				'''
		}

		bossLife: {
			Label: Boss血量倍率
			Tooltip:
				'''
				模组启用且你想的话，允许你增加Boss的血量
				以防你觉得此模组过于强力，想要削弱它
				'''
		}

		enemyLife: {
			Label: 敌怪血量倍率
			Tooltip:
				'''
				模组启用且你想的话，允许你增加非Boss敌怪的血量
				以防你觉得此模组过于超模，想要削弱它
				'''
		}

		travellingMerchantWhetstones: {
			Label: 旅商售卖砥石
			Tooltip: 启用后，旅行商人会贩卖给你随机效果的基础砥石
		}
	}
}

