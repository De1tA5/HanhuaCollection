			'''
	}

	ShortestStraw: {
		DisplayName: 最短的稻草
		Tooltip:
			'''
			敌怪的生命值越低，提升的暴击伤害越高，最高25%
			增加5%连续暴击伤害
			“余波已然开始，压迫造成伤害”
			[C/959595:出自 Metallica - 《The Shortest Straw》]
			'''
	}

	Greenprint: {
		DisplayName: 绿染印纸
		Tooltip:
			'''
			丛林蜥蜴各种造物的详细说明书
			被染成绿色是因为丛林蜥蜴使用来自丛林的植物纤维的印刷工艺导致的
			'''
	}

	PocketLightningRod: {
		DisplayName: 便捷避雷针
		Tooltip:
			'''
			暴击时产生弧状闪电攻击路径上的所有敌怪
			它的威力相当……惊人
			'''
		CanBeApplied: ""
	}

	AMPL: {
		CanBeApplied: 只能被安装在远程武器上
		DisplayName: A.M.P.L.
		Tooltip:
			'''
			当被安装在武器上时，会禁用普通暴击
			当武器造成暴击时会发射追踪导弹
			追踪导弹会在较大范围内造成武器的普通暴击伤害
			有1秒冷却时间
			'''
	}

	HoneydippedStinger: {
		CanBeApplied: ""
		DisplayName: 浸蜜毒刺
		Tooltip:
			'''
			当被安装在武器上时，会禁用普通暴击
			当武器造成暴击时治疗玩家一些生命值
			治疗量与暴击伤害倍率和效力有关
			'''
	}

	Boomstickifier: {
		CanBeApplied: 只能被安装在矛上
		DisplayName: 爆炸杆改装器
		Tooltip:
			'''
			当被安装在武器上时，会禁用普通暴击
			当武器造成暴击时造成2倍暴击伤害的爆炸
			店主不对不良后果负责
			不会破坏物块
			“实际上就是矛上绑了个炸药”
			'''
	}

	Buckler: {
		CanBeApplied: ""
		DisplayName: 圆盾
		Tooltip:
			'''
			当被安装在武器上时，会禁用普通暴击
			相反，你在1秒内获得根据暴击伤害倍率和效力而提升的额外防御
			当你获得增益并受到伤害时，防御会转换为伤害加成，持续3秒
			伤害加成时期你可以再次造成暴击
			在这之后，你会获得10秒脆弱，无法再次使用圆盾
			'''
	}

	CursersQuill: {
		CanBeApplied: ""
		DisplayName: 诅咒者的羽毛笔
		Tooltip:
			'''
			当被安装在武器上时，会禁用普通暴击
			相反，将会提取受击敌怪的灵魂，并储存在暴击中
			当你使用不同的武器造成暴击时，所有的灵魂将会被释放造成暴击伤害
			默认最高存储10个灵魂，每有10%效力增加1个存储量
			'''
	}

	ThornRing: {
		CanBeApplied: ""
		DisplayName: 荆棘戒指
		Tooltip:
			'''
			当被安装在武器上时，会禁用普通暴击
			相反，暴击伤害将通过附着敌怪的荆棘造成，荆棘持续3秒
			当敌怪死亡时，他们的荆棘会射向其他敌怪
			“[c/fc0303:前进]”
			'''
	}

	HuntersDrawstring: {
		CanBeApplied: 只能被安装在弓和弩上
		DisplayName: 猎人的弓弦
		Tooltip:
			'''
			当被安装在武器上时，会禁用普通暴击
			相反，施加目标[C/D26A1A:猎人的标记]减益，这会增加25%非箭矢暴击伤害
			标记的持续时间与暴击伤害倍率和效力有关
			'''
	}

