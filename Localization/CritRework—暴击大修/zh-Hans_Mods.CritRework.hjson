Configs: {
	ClientConfig: {
		DisplayName: 客户端设置
		Headers.AestheticHeader: 美术相关

		overrideCritColor: {
			Label: 覆盖原版暴击颜色
			Tooltip: 启用后，能改变暴击文本的颜色（见下）
		}

		critColor: {
			Label: 暴击颜色
			Tooltip: 如果上述设置启用，则更改暴击文本的颜色
		}

		critSoundEffect: {
			Label: 暴击音效
			Tooltip: 启用/禁用击中敌怪时的暴击音效
		}

		showActiveCrits: {
			Label: 物品栏显示激活暴击物品
			Tooltip: 启用后，物品栏中满足暴击条件的物品将高亮显示
		}

		hideGloveDescription: {
			Label: 隐藏手套教程
			Tooltip: 启用后，手套的教程说明将从其工具提示中移除以减少冗杂信息
		}
		abbreviateWhetstoneTooltip: {
			Label: 简化砥石文本
			Tooltip: 启用后，砥石的教程说明将从其工具提示中移除以减少冗杂信息
		}

		abbreviateAugmentationTooltip: {
			Label: 简化强化部件文本
			Tooltip: 启用后，强化部件的教程说明将从其工具提示中移除以减少冗杂信息
		}
	}

	ServerConfig: {
		DisplayName: 服务器设置

		Headers: {
			BalanceHeader: 平衡
			ContentHeader: 内容
		}

		critPower: {
			Label: 暴击强度
			Tooltip:
				'''
				允许你调整暴击伤害强度
				设置为 0 ，则所有暴击伤害和普通伤害相同
				设置为 2 ，则所有暴击伤害翻倍
				'''
		}

		pirateHijack: {
			Label: 海盗劫持
			Tooltip:
				'''
				启用后，海盗有新特性
				允许你在不重铸的情况下改变武器的暴击条件
				'''
		}

		randomHijackChance: {
			Label: 重铸劫持几率
			Tooltip: 在哥布林工匠重铸时武器有概率被“劫持”，将会改变武器暴击条件
		}

		randomHijackSound: {
			Label: 重铸劫持音效
			Tooltip: 启用后，在武器被劫持时发生特殊音效（见上）
		}

		pirateArmorRework: {
			Label: "[i:876]海盗套装重做"
			Tooltip: 启用后，由海盗出售的[i:876]海盗时装 具有实际盔甲效果
		}

		gloveDamageType: {
			Label: 手套/标枪职业伤害
			Tooltip:
				'''
				该伤害类型将应用于手套/标枪武器
				如果未启用《灾厄》模组，且设置为盗贼，则默认为远程伤害
				请在Steam创意工坊上评论任何你认为应该添加的伤害类型
				'''
		}

		critScaling: {
			Label: 暴击倍率计算方式
			Tooltip:
				'''
				根据暴击伤害倍率/暴击率加成，决定暴击伤害的计算方式
				最推荐“平衡”模式，但“简单”模式通常更强且易于理解，你可能更喜欢
				平衡 - （（武器伤害倍率-1）*（（100+武器暴击率）/99）/2+1）+1)*(1+(（100+武器暴击率）/99)/2)
				简单 - 武器伤害倍率 * （1+武器暴击率）
				'''
		}

		bossLife: {
			Label: Boss血量倍率
			Tooltip:
				'''
				模组启用且你想的话，允许你增加Boss的血量
				以防你觉得此模组过于强力，想要削弱它
				'''
		}

		enemyLife: {
			Label: 敌怪血量倍率
			Tooltip:
				'''
				模组启用且你想的话，允许你增加非Boss敌怪的血量
				以防你觉得此模组过于强力，想要削弱它
				'''
		}

		travellingMerchantWhetstones: {
			Label: 旅商售卖砥石
			Tooltip: 启用后，旅行商人会贩卖给你随机效果的基础磨刀石
		}
	}
}

CritTypes: {
	AboveFoe.Description: 处于目标上方时造成暴击
	BelowFoe.Description: 处于目标下方时造成暴击
	BunchedUpFoes.Description: 当有许多敌怪相互靠近时造成暴击
	CloseToFoe.Description: 当你距离目标不到6格时造成暴击
	ElfMelter.Description: 目标具有史莱姆减益时造成暴击
	Falling.Description: 当你坠落时造成暴击
	FarFromFoe.Description: 当你距离目标超过40多格时造成暴击
	Flamethrower.Description: 目标具有史莱姆减益时造成暴击
	FoeAtHighHP.Description: 目标血量超过85%时造成暴击
	FoeAtLowHP.Description: 目标生命值低于25%时造成暴击
	FoeConfused.Description: 目标具有困惑减益时造成暴击
	FoeHasFourDebuffs.Description: 目标具有4个以上的减益时造成暴击
	FoeHasThreeDebuffs.Description: 目标具有3个以上的减益时造成暴击
	FoeHasTwoDebuffs.Description: 目标具有2个以上的减益时造成暴击
	FoeIsWet.Description: 目标具有潮湿减益或者处于水下时造成暴击
	FoeOnFire.Description: 目标具有火系减益时造成暴击
	FoePoisoned.Description: 目标具有毒系减益时造成暴击
	HighChance.Description: 25%概率造成暴击
	LowChance.Description: 1%概率造成暴击
	MediumChance.Description: 10%概率造成暴击
	MovingFast.Description: 当你移动速度超过60 mph时造成暴击
	PlayerNohit.Description: 如果你超过15秒未受到伤害则造成暴击
	StandingStill.Description: 当你移动速度低于10 mph时造成暴击
	TipOfTheWeapon.Description: 使用武器尖端部分攻击敌怪造成暴击
	CrystalVileShard.Description: 使用魔晶碎块的尖端攻击敌怪时造成暴击
	FreshItem.Description: 在切换该武器后一小段时间内造成暴击
	Harpoon.Description: 当你距离目标至少26格远时造成暴击
	JustHitByEnemy.Description: 受伤后2.5秒内造成暴击
	ProjectileTravel.Description: 若弹幕飞行超过1秒则造成暴击
	ShadowbeamStaff.Description: 暗影射线在墙上反弹时造成暴击
	ShadowflameKnife.Description: 暗影焰刀反弹至少一个目标后造成暴击
	Shuriken.Description: 手里剑至少击中一个目标后造成暴击
	Sniper.Description: 当你距离目标至少75格远时造成暴击
	SpikyBall.Description: 存在超过5秒后造成暴击
	ThrowingKnife.Description: 投刀坠落时造成暴击
	Vilethorn.Description: 使用荆棘尖端攻击敌怪造成暴击
	Adaptive.Description: 治疗至少20点生命值后3秒能造成暴击（满血治疗不算入内）
	Ammo.Description: 此次攻击不消耗弹药时则造成暴击
	Ancient.Description: 在你重生后60秒内造成暴击
	Enchanted.Description: 你的魔力值低于30%则造成暴击
	Frozen.Description: 目标移动速度低于10 mph时造成暴击
	Greedy.Description: 拾取钱币后3秒内造成暴击
	Necromantic.Description: 另一位玩家处于死亡状态则造成暴击
	Soaring.Description: 当你坠落或滑翔至少4秒后造成暴击
	Starter.Description: 如果你最大生命值低于200则造成暴击
	WebCovered.Description: 使用钩爪抓住物块过程中超过1秒，或已抓住物块则造成暴击
	Boomerangs.Description: 回旋镖回归时造成暴击
	Prepared.Description: 在攻击激活5秒后造成暴击
	Holy.Description: 当你处于无敌帧状态时造成暴击（如受到伤害）
	CritWithAnother.Description: 其他武器暴击后3秒内该武器造成暴击
	BronzeBowCrit.Description: 当目标距离你15-20个物块之间则造成暴击
	TenSecondCooldown.Description: 如果你最后一次暴击至少是在10秒前则造成暴击
	ThreeSecondCooldown.Description: 如果你最后一次暴击至少是在3秒前则造成暴击
	Backstab.Description: 当你从背后攻击敌怪（大部分）时造成暴击
	PickUpAmmo.Description: Mods.CritRework.CritTypes.PickUpAmmo.Description
	HasDebuff.Description: 当你被施加随时间造成伤害的效果（如：着火了！）时造成暴击
