	}

	WindWalker: {
		DisplayName: 风行者
		Tooltip: 暴击时提升你的移动速度，持续3秒
	}

	BloodCog: {
		CanBeApplied: 只能被安装在枪械和部分魔法杖上
		DisplayName: 血腥齿轮
		Tooltip:
			'''
			为强化的武器安装链锯，降低精准度
			暴击时会转动链锯，造成近距离伤害
			转动时间与暴击伤害倍率和效力有关
			链锯激活时会大幅降低精准度
			“人类或许尚未灭绝，但这玩意会让我们更快走向灭绝”
			'''
	}

	ImperfectStorm: {
		CanBeApplied: 只能被安装在近战武器上
		DisplayName: 瑕缺风暴
		Tooltip:
			'''
			当被安装在武器上时，会禁用普通暴击
			相反，未暴击时召唤最多20个现实切割
			当你造成暴击时，每个现实切割会立刻造成暴击伤害
			“我即是那迫近的风暴”
			[C/959595:出自 Devil May Cry 5 - 《Bury the Light》]
			'''
	}

	Horrificracker: {
		DisplayName: 惊恐饼干
		Tooltip:
			'''
			可以被附加暴击条件
			装备时，所有仆从将继承暴击条件
			增加1个最大仆从栏
			'''
	}

	GildedRemains: {
		DisplayName: 镀金遗骨
		Tooltip:
			'''
			只在被收藏时激活
			当激活时，在哥布林工匠重铸不再改变物品的暴击条件
			“据说曾被弥达斯接触过，但其真实性……有待商榷”
			'''
	}

	SkywardSling: {
		DisplayName: 天际投石索
		Tooltip:
			'''
			允许你给武器额外安装一个强化部件
			增加5%暴击率
			'''
	}

	GraftedSling: {
		DisplayName: 融合投掷臂甲
		Tooltip:
			'''
			允许你给武器额外安装一个强化部件
			能够被给予暴击条件
			所有武器将继承此暴击条件，除此之外还保留它们自己的暴击条件
			两个暴击条件必须同时被满足才能造成暴击：
			'''
	}

	ContaminatedSapling: {
		DisplayName: 污染树苗
		Tooltip:
			'''
			武器每安装一个强化部件增加10%暴击率
